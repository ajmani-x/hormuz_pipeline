# hormuz_pipeline local secrets — copy this file to .env and fill in your
# own key. .env is gitignored and never committed; this example file is
# safe to commit since it contains no real secret.
#
#   cp .env.example .env
#
# The only key this project needs: a Groq API key for the RAG agent's LLM
# calls (server.py -> /api/ask). Everything else (GDELT news, Yahoo Finance
# prices, straits.live AIS data) is free and keyless.
#
# Get a free key at https://console.groq.com
GROQ_API_KEY=
