# hormuz_pipeline local secrets — copy this file to .env and fill in your
# own key. .env is gitignored and never committed; this example file is
# safe to commit since it contains no real secret.
#
#   cp .env.example .env
#
# The only REQUIRED key: a Groq API key for the RAG agent's LLM calls
# (server.py -> /api/ask). The live data feeds (GDELT news, Yahoo Finance
# prices, straits.live AIS data) are free and keyless.
#
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# OPTIONAL: an EIA Open Data key (free, https://www.eia.gov/opendata/) —
# used as a backup source for Brent/WTI spot prices when Yahoo Finance is
# unreachable. Everything degrades gracefully without it (last-known-good
# cache, then published baseline levels).
EIA_API_KEY=
